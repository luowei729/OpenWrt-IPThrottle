#!/bin/sh
# ==========================================
# OpenWrt IPThrottle 插件 - CLI 入口
# 文件: /usr/sbin/ipthrottle
# 功能: 提供 start/stop/reload/status/apply 命令
# 创建时间: 2026-06-09
# 修改时间: 2026-06-10 (修复为正确的 CLI 入口)
# ==========================================

# 加载核心模块
. /usr/lib/ipthrottle/core.sh

# 显示用法
usage() {
    echo "Usage: $0 {start|stop|reload|status|apply}"
    echo "  start   - 启动限速服务"
    echo "  stop    - 停止限速服务"
    echo "  reload  - 重新加载配置并应用规则"
    echo "  status  - 显示服务状态"
    echo "  apply   - 立即应用当前配置（不重启服务）"
    exit 1
}

# 参数检查
[ $# -lt 1 ] && usage

case "$1" in
    start)
        start_service
        ;;
    stop)
        stop_service
        ;;
    reload)
        reload_service
        ;;
    status)
        # 检查 nftables 表是否存在
        if nft list table ip ipthrottle >/dev/null 2>&1; then
            echo "ipthrottle: running"
            # 显示 IP 限速规则数量（prerouting chain 中的 limit 规则）
            RULE_COUNT=$(nft list table ip ipthrottle 2>/dev/null | grep -c "limit rate over")
            echo "  Active IP throttle rules: $RULE_COUNT"
        else
            echo "ipthrottle: stopped"
        fi
        ;;
    apply)
        cmd_apply
        ;;
    *)
        usage
        ;;
esac

exit 0
