#!/bin/sh /etc/rc.common
# OpenWrt init script for IPThrottle daemon

START=99
STOP=01

USE_PROCD=1

# 加载依赖检测脚本
. /usr/lib/ipthrottle/deps.sh

# 检测包管理器是否正在运行（被锁定）
# 实现原因: opkg/apk 安装期间持有锁文件，此时 deps.sh 尝试安装依赖会死锁。
# 用 flock 测试锁是否被占用：flock -n 获取非阻塞锁，成功说明未被占用。
# 返回值: 0=锁可用(可以安装依赖) 1=锁被占(包管理器正在运行)
is_pkg_locked() {
    local lock_file=""
    
    if command -v apk >/dev/null 2>&1; then
        lock_file="/lib/apk/db/lock"
    elif command -v opkg >/dev/null 2>&1; then
        lock_file="/var/lock/opkg.lock"
    else
        return 0
    fi
    
    # 锁文件不存在 → 未锁定
    [ ! -f "$lock_file" ] && return 0
    
    # 用 flock 测试锁是否被占用
    # flock -n: 非阻塞尝试，成功=锁可用，失败=被占
    ( flock -n 9 2>/dev/null || return 1 ) 9>"$lock_file"
}

start_service() {
    # 检测包管理器是否正在运行
    # 实现原因: opkg/apk 安装期间会触发服务启动，此时不能安装依赖（会死锁）
    # 跳过依赖检查，直接启动服务，依赖会在首次手动 start 或 reload 时安装
    if ! is_pkg_locked; then
        logger -t ipthrottle "Package manager running, skipping deps install (will install on next start)"
        
        # 启动 daemon 骨架，但跳过依赖安装
        # daemon 启动后会检测环境，缺少 tc/nft 时会记录警告日志但不崩溃
        procd_open_instance
        procd_set_param command /usr/lib/ipthrottle/ipthrottle-daemon
        procd_set_param stdout 1
        procd_set_param stderr 1
        procd_close_instance
        return 0
    fi
    
    # 包管理器可用，正常检查依赖
    if ! check_all_deps; then
        logger -t ipthrottle "ERROR: Dependencies check failed, service not started"
        return 1
    fi
    
    procd_open_instance
    procd_set_param command /usr/lib/ipthrottle/ipthrottle-daemon
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "ipthrottle"
}

reload_service() {
    /usr/sbin/ipthrottle reload
}
