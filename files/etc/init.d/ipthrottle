#!/bin/sh /etc/rc.common
# OpenWrt init script for IPThrottle daemon

START=99
STOP=01

USE_PROCD=1

# 加载依赖检测脚本（只检测，不安装）
. /usr/lib/ipthrottle/deps.sh

start_service() {
    # 设计原因: 包安装期间 procd 会触发服务启动，此时 opkg/apk 锁被占。
    # 方案: 先启动服务骨架，后台延时安装缺失依赖（避免死锁）。
    # 用户手动重启 (/etc/init.d/ipthrottle restart) 时，锁已释放，正常安装。
    
    # 1. 启动服务（即使缺少部分依赖，daemon 会记日志提示）
    procd_open_instance
    procd_set_param command /usr/lib/ipthrottle/ipthrottle-daemon
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
    
    # 2. 后台延时安装缺失的依赖（不阻塞启动）
    deferred_install_deps
}

service_triggers() {
    procd_add_reload_trigger "ipthrottle"
}

reload_service() {
    /usr/sbin/ipthrottle reload
}
