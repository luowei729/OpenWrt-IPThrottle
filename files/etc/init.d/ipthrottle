#!/bin/sh /etc/rc.common
# OpenWrt init script for IPThrottle daemon

START=99
STOP=01

USE_PROCD=1

# 加载依赖检测脚本（只检测，不安装）
. /usr/lib/ipthrottle/deps.sh

start_service() {
    # 检测依赖（只检查+警告，不调用 opkg/apk）
    # 设计原因: 依赖安装由包管理器在 opkg/apk install 时原子完成，
    # 此处只做运行时检测，避免死锁
    if ! check_all_deps; then
        logger -t ipthrottle "WARNING: Some deps missing, service may not work. Install manually then restart."
        # 仍然启动 daemon，让用户看到界面并能手动安装依赖后重启生效
    fi
    
    procd_open_instance
    procd_set_param command /usr/lib/ipthrottle/ipthrottle-daemon
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "ipthrottle"
}

reload_service() {
    /usr/sbin/ipthrottle reload
}
