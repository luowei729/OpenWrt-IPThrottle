#!/bin/sh /etc/rc.common
# OpenWrt init script for IPThrottle daemon

START=99
STOP=01

USE_PROCD=1

# 加载依赖检测脚本
. /usr/lib/ipthrottle/deps.sh

# 等待包管理器锁释放
# 实现原因: 包安装后 procd 自动启动服务，此时包管理器(opkg/apk)可能仍在运行，
# 数据库被锁。如果此时 deps.sh 尝试安装依赖，会因锁冲突而失败。
# 此函数检测锁文件是否存在，等待锁释放后再继续。
wait_pkg_lock() {
    local max_wait=60
    local waited=0
    local lock_file=""
    local pkg_name=""
    
    # 根据包管理器类型确定锁文件路径
    if command -v apk >/dev/null 2>&1; then
        # OpenWrt 25+ 使用 apk
        lock_file="/lib/apk/db/lock"
        pkg_name="apk"
    elif command -v opkg >/dev/null 2>&1; then
        # OpenWrt 23/24 使用 opkg
        lock_file="/var/lock/opkg.lock"
        pkg_name="opkg"
    else
        return 0
    fi
    
    # 循环等待锁文件消失
    while [ -f "$lock_file" ] && [ $waited -lt $max_wait ]; do
        logger -t ipthrottle "Waiting for ${pkg_name} lock to release (${waited}s/${max_wait}s)..."
        sleep 2
        waited=$((waited + 2))
    done
    
    if [ $waited -ge $max_wait ]; then
        logger -t ipthrottle "WARNING: ${pkg_name} lock wait timeout (${max_wait}s), proceeding anyway"
    fi
}

start_service() {
    # 等待包管理器锁释放（避免 apk add 锁冲突）
    wait_pkg_lock
    
    # 启动前检查依赖
    if ! check_all_deps; then
        logger -t ipthrottle "ERROR: Dependencies check failed, service not started"
        return 1
    fi
    
    procd_open_instance
    procd_set_param command /usr/lib/ipthrottle/ipthrottle-daemon
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "ipthrottle"
}

reload_service() {
    /usr/sbin/ipthrottle reload
}
