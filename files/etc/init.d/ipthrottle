#!/bin/sh /etc/rc.common
# OpenWrt init script for IPThrottle daemon

START=99
STOP=01

USE_PROCD=1

# 加载依赖检测脚本（只检测，不安装）
. /usr/lib/ipthrottle/deps.sh

start_service() {
    # 检测依赖是否就绪（只检查+警告，不安装）
    # 依赖安装由 postinstall.sh 在安装时完成（等待包管理器锁释放后同步安装）
    # 若安装时锁超时导致部分 kmod 缺失，用户手动 restart 前执行：
    #   opkg install kmod-ifb kmod-sched-htb   或
    #   apk add kmod-ifb kmod-sched-htb
    check_all_deps
    
    procd_open_instance
    procd_set_param command /usr/lib/ipthrottle/ipthrottle-daemon
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "ipthrottle"
}

reload_service() {
    /usr/sbin/ipthrottle reload
}
